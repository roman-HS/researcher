# Required for server-side features (auth, API routes, etc.)
NODE_ENV=development
APP_URL=http://localhost:3000

# Phase 2 — Supabase Postgres (single cloud project until branching is enabled)
# Runtime (transaction pooler, port 6543). Use prepare: false with Drizzle/postgres.js.
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:6543/postgres
# Migrations (session pooler or direct connection, port 5432) for drizzle-kit.
# DATABASE_DIRECT_URL=postgresql://postgres.[project-ref]:[password]@[region].pooler.supabase.com:5432/postgres
#
# V1 uses Supabase as managed Postgres only. Disable PostgREST in the Supabase dashboard:
# Project Settings → API → Enable Data API → off
#
# Production Supabase project: deferred until Supabase branching is enabled.
# Preview deployments: use the same DATABASE_URL as local dev for now.
#
# Database scripts (see docs/implementation/database-migrations.md):
#   pnpm db:generate         — drizzle-kit generate → supabase/migrations/
#   pnpm db:push             — apply locally via supabase db push
#   pnpm db:migrate          — alias for db:push
#   pnpm db:migrate:prod     — production apply (DATABASE_DIRECT_URL in shell only)
#   pnpm db:status           — list applied migrations
#   pnpm db:check-migrations — flag destructive SQL in changed migrations
# Required once auth routes are mounted (Story 2.2.2+). Generate with: pnpm exec better-auth secret
# BETTER_AUTH_SECRET=
# Optional comma-separated extra trusted origins (e.g. Vercel preview URLs). APP_URL is always trusted via baseURL.
# BETTER_AUTH_TRUSTED_ORIGINS=

# Phase 3 — RapidAPI provider integration
# RAPIDAPI_HOST=
# RAPIDAPI_KEY=
# RAPIDAPI_TIMEOUT_MS=30000

# Phase 7 — workflow execution transport (direct for local dev, vercel_workflows for production)
EXECUTION_TRANSPORT=direct
